# =============================================================================
# MZADAK Backend — Local Development Environment
# Copy to .env:  cp .env.example .env
# =============================================================================

# ── General ──────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development
APP_NAME=MZADAK
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ── API ──────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5555"]

# ── PostgreSQL ───────────────────────────────────────────────────
# Host is "postgres" inside Docker, "localhost" if running bare-metal
DATABASE_URL=postgresql+asyncpg://mzadak:mzadak@postgres:5432/mzadak
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Redis ────────────────────────────────────────────────────────
# Host is "redis" inside Docker, "localhost" if running bare-metal
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ── Celery ───────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT RS256 ────────────────────────────────────────────────────
# Generate keys:
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OTP / Auth ───────────────────────────────────────────────────
OTP_EXPIRE_SECONDS=300
OTP_MAX_REQUESTS_PER_HOUR=5
OTP_MAX_VERIFY_ATTEMPTS=3
OTP_LOCKOUT_SECONDS=900

# ── SMS ──────────────────────────────────────────────────────────
SMS_PROVIDER=mock
AWS_SNS_REGION=me-south-1

# ── KYC ──────────────────────────────────────────────────────────
KYC_AUTO_APPROVE_THRESHOLD=85.0
KYC_MANUAL_REVIEW_THRESHOLD=70.0
KYC_MAX_ATTEMPTS=2
KYC_PRESIGNED_URL_EXPIRY=300
KYC_REVIEWER_URL_EXPIRY=300

# ── Listings ─────────────────────────────────────────────────────
LISTING_MAX_ACTIVE_FREE=5
LISTING_MIN_DURATION_HOURS=1
LISTING_MAX_DURATION_DAYS=7
LISTING_MODERATION_THRESHOLD=70.0
LISTING_PHASH_THRESHOLD=92
LISTING_PRESIGNED_URL_EXPIRY=300
LISTING_THUMBNAIL_SIZES=[100,400,800]
MAX_LISTING_IMAGES=20

# ── Meilisearch ──────────────────────────────────────────────────
# Host is "meilisearch" inside Docker, "localhost" if running bare-metal
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_API_KEY=mzadak_dev_key

# ── Checkout.com (Payments) ─────────────────────────────────────
# Get test keys from https://hub.checkout.com
CHECKOUT_SECRET_KEY=
CHECKOUT_PUBLIC_KEY=
CHECKOUT_WEBHOOK_SECRET=
CHECKOUT_SUCCESS_URL=https://mzadak.com/payment/success
CHECKOUT_FAILURE_URL=https://mzadak.com/payment/failure
PLATFORM_FEE_PERCENT=10.0

# ── AWS (S3 / Rekognition / Secrets Manager) ─────────────────────
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_MEDIA=mzadak-media-dev
S3_BUCKET_KYC=mzadak-kyc-dev

# ── ClickHouse (analytics) ──────────────────────────────────────
# Host is "clickhouse" inside Docker, "localhost" if running bare-metal
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=mzadak_analytics

# ── Snap-to-List / AI ───────────────────────────────────────────
SNAP_TO_LIST_TIMEOUT=8.0
SNAP_TO_LIST_CLIP_MIN_CONFIDENCE=40.0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Price Oracle ─────────────────────────────────────────────────
PRICE_ORACLE_CACHE_TTL=3600
PRICE_ORACLE_LOOKBACK_DAYS=90
PRICE_ORACLE_MIN_COMPARABLES=3
PRICE_ORACLE_MODEL_PATH=models/price_oracle.joblib

# ── Twilio (SMS / WhatsApp) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Firebase (FCM push notifications) ───────────────────────────
FIREBASE_CREDENTIALS_PATH=

# ── WhatsApp Bot ─────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=mzadak_wa_verify_dev
META_WEBHOOK_SECRET=
WHATSAPP_RATE_LIMIT_PER_DAY=5

# ── Email (SMTP / SendGrid) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@mzadak.com
SMTP_FROM_NAME=MZADAK
SENDGRID_API_KEY=
EMAIL_PROVIDER=smtp

# ── Rate limits ──────────────────────────────────────────────────
RATE_LIMIT_AUTH=1000
RATE_LIMIT_UNAUTH=100
RATE_LIMIT_BID_PER_MINUTE=10

# ── Auction defaults ─────────────────────────────────────────────
ANTI_SNIPE_WINDOW_SECONDS=120
ANTI_SNIPE_EXTENSION_SECONDS=120
MAX_ANTI_SNIPE_EXTENSIONS=5
DEFAULT_MIN_INCREMENT=25.0

# ── Escrow deadlines ─────────────────────────────────────────────
PAYMENT_DEADLINE_HOURS=24
SHIPPING_DEADLINE_HOURS=48
INSPECTION_DEADLINE_HOURS=48
EVIDENCE_DEADLINE_HOURS=24
