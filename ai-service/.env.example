# ═══════════════════════════════════════════════════════════════════
# MZADAK AI Service — Local Development Environment
# Copy to .env:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

DEBUG=true
GPU_ENABLED=false
MODEL_CACHE_DIR=/app/model_cache

# ── Redis (shared with backend, db 1) ────────────────────────────
REDIS_URL=redis://redis:6379/1

# ── Backend API ──────────────────────────────────────────────────
BACKEND_URL=http://api:8000

# ── OpenAI (for GPT-4o content generation + moderation) ──────────
OPENAI_API_KEY=

# ── AWS (S3 image access for CLIP classification) ────────────────
S3_BUCKET=mzadak-media-dev
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── ClickHouse (price oracle comparables — optional) ─────────────
CLICKHOUSE_URL=
